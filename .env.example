# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Auth + database
DATABASE_URL=postgresql://user:password@host:5432/unified_social_analytics?sslmode=disable
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth for login and YouTube channel connection
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_YOUTUBE_REDIRECT_URL=http://localhost:3000/api/youtube/callback
YOUTUBE_OAUTH_STATE_SECRET=replace-with-a-long-random-secret

# OpenAI Responses API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Vercel Cron
CRON_SECRET=replace-with-a-long-random-secret
